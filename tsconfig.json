{
  "extends": "./node_modules/qcobjects-tsconfig/tsconfig.json",
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "allowJs": true,
    "checkJs": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./build",
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["node", "jasmine"],
    "paths": {
      "qcobjects": ["node_modules/qcobjects"],
      "qcobjects-sdk": ["node_modules/qcobjects-sdk"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "build", "public"]
}
