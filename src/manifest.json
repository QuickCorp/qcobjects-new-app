{
  "background_color": "#FFFFFF",
  "description": "A powerful and intuitive application built with QCObjects that helps you manage your tasks and boost productivity. Features offline support, real-time updates, and seamless cross-device synchronization.",
  "dir": "ltr",
  "display": "standalone",
  "name": "QCObjects Task Manager",
  "orientation": "any",
  "scope": "/",
  "short_name": "QCTasks",
  "start_url": "/?source=pwa",
  "theme_color": "#2196F3",
  "shortcuts": [
    {
      "name": "New Task",
      "short_name": "Add",
      "description": "Create a new task",
      "url": "/new?source=shortcut",
      "icons": [{ "src": "img/icons/add-task.png", "sizes": "192x192" }]
    },
    {
      "name": "View Tasks",
      "short_name": "Tasks",
      "description": "View your task list",
      "url": "/tasks?source=shortcut",
      "icons": [{ "src": "img/icons/view-tasks.png", "sizes": "192x192" }]
    }
  ],
  "lang": "en-US",
  "categories": [
    "productivity",
    "utilities",
    "lifestyle"
  ],
  "icons": [
