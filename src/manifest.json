  "splash_pages": null,
  "prefer_related_applications": false,
  "related_applications": [
    {
      "platform": "play",
      "url": "https://play.google.com/store/apps/details?id=com.example.qcobjects_newapp",
      "id": "com.example.qcobjects_newapp"
    },
    {
      "platform": "itunes",
      "url": "https://itunes.apple.com/app/qcobjects_newapp/id123456789"
    }
  ],
  "display_override": [
    "window-controls-overlay",
    "standalone",
    "minimal-ui"
  ],
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": ["navigate-existing", "auto"]
  },
  "edge_side_panel": {
    "preferred_width": 400
  },
  "file_handlers": [
    {
      "action": "/open-task",
      "accept": {
        "application/json": [".task"]
      },
      "icons": [
        {
          "src": "img/icons/task-file.png",
          "sizes": "256x256",
          "type": "image/png"
        }
      ],
      "launch_type": "single-client"
    }
  ]
